# Backend-focused environment example.
# The canonical full-stack template lives at ../.env.example.

# Provider-aware runtime defaults (used for live sessions when no override is supplied)
LLM_PROVIDER=openrouter
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
LLM_EMBED_MODEL=openai/text-embedding-3-small
LLM_BASE_URL=https://openrouter.ai/api/v1/
LLM_TIMEOUT_SECONDS=60
OLLAMA_LLM_TIMEOUT_SECONDS=120
LLM_AUTO_PULL_OLLAMA_MODELS=true

# Provider credentials
GEMINI_API_KEY=
GEMINI_API=
OPENAI_API_KEY=
OPENAI_API=
OPENROUTER_API_KEY=

# Optional provider-specific defaults
GOOGLE_DEFAULT_MODEL=gemini-2.5-flash-lite
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENROUTER_DEFAULT_MODEL=openai/gpt-5-mini
OLLAMA_DEFAULT_MODEL=qwen3:4b-instruct-2507-q4_K_M
OLLAMA_DEFAULT_EMBED_MODEL=nomic-embed-text

# OASIS runtime (Python 3.11 sidecar)
ENABLE_REAL_OASIS=false
OASIS_PYTHON_BIN=.venv311/bin/python
OASIS_RUNNER_SCRIPT=scripts/oasis_reddit_runner.py
OASIS_DB_DIR=data/oasis

# Singapore planning area GeoJSON source (Data.gov)
DATAGOV_API_KEY=
PLANNING_AREA_DATASET_ID=d_4765db0e87b9c86336792efe8a1f7a66
PLANNING_AREA_GEOJSON_CACHE_PATH=data/geo/planning_area_boundaries.geojson

# Data source
NEMOTRON_DATASET=nvidia/Nemotron-Personas-Singapore
NEMOTRON_SPLIT=train
LIGHTRAG_WORKDIR=data/lightrag
DEMO_DEFAULT_POLICY_MARKDOWN=Sample_Inputs/singapore_budget_ai_strategic_advantage.md
