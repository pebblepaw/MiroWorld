# Root environment example for the repository launcher, backend, and frontend.
# Copy this file to `.env` and customize the values you need.

# Launcher hosts and ports used by `quick_start.sh`.
PY_BIN=".venv/bin/python"
OASIS_PY_BIN="backend/.venv311/bin/python"
OASIS_PYTHON_BIN="backend/.venv311/bin/python"
BACKEND_HOST="127.0.0.1"
BACKEND_PORT="8000"
FRONTEND_HOST="127.0.0.1"
FRONTEND_PORT="5173"

# Frontend runtime settings.
VITE_API_BASE="http://127.0.0.1:8000"
VITE_BOOT_MODE="demo"

# Local LLM/provider defaults used by the launcher and backend settings.
LLM_PROVIDER="ollama"
LLM_MODEL="qwen3:4b-instruct-2507-q4_K_M"
LLM_EMBED_MODEL="nomic-embed-text"
LLM_BASE_URL="http://127.0.0.1:11434/v1/"
LLM_API_KEY=""
LLM_TIMEOUT_SECONDS="20"
OLLAMA_LLM_TIMEOUT_SECONDS="120"
LLM_AUTO_PULL_OLLAMA_MODELS="true"

# Provider aliases and legacy compatibility keys.
OPENAI_API_KEY=""
OPENAI_API=""
OPENROUTER_API_KEY=""
GEMINI_API_KEY=""
GEMINI_API=""
ZEP_API_KEY=""
ZEP_CLOUD=""

# Dataset, cache, and storage paths.
NEMOTRON_DATASET="nvidia/Nemotron-Personas-Singapore"
NEMOTRON_SPLIT="train"
NEMOTRON_CACHE_DIR="data/nemotron"
NEMOTRON_DOWNLOAD_WORKERS="4"
LIGHTRAG_WORKDIR="data/lightrag"
SIMULATION_DB_PATH="data/simulation.db"
CONSOLE_DEMO_OUTPUT_PATH="data/demo-output.json"
CONSOLE_DEMO_FRONTEND_OUTPUT_PATH="../frontend/public/demo-output.json"
CONSOLE_UPLOAD_DIR="data/uploads"
PLANNING_AREA_GEOJSON_CACHE_PATH="data/geo/planning_area_boundaries.geojson"
FRONTEND_DIST_PATH="../frontend/dist"

# Simulation and OASIS runtime defaults.
DEMO_DEFAULT_POLICY_MARKDOWN="Sample_Inputs/fy2026_budget_statement.md"
DEFAULT_AGENT_COUNT="50"
DEFAULT_ROUNDS="10"
SIMULATION_PLATFORM="reddit"
ENABLE_REAL_OASIS="false"
OASIS_RUNNER_SCRIPT="scripts/oasis_reddit_runner.py"
OASIS_DB_DIR="data/oasis"
OASIS_TIMEOUT_SECONDS="1800"
OASIS_OLLAMA_TIMEOUT_PER_AGENT_ROUND_SECONDS="12"
OASIS_DEFAULT_TIMEOUT_PER_AGENT_ROUND_SECONDS="3"
OASIS_OLLAMA_SEMAPHORE="12"
OASIS_DEFAULT_SEMAPHORE="64"
OASIS_RUN_LOG_DIR="data/oasis/logs"

# Streaming and integration knobs.
SIMULATION_STREAM_HEARTBEAT_SECONDS="5"
SIMULATION_STREAM_REPLAY_LIMIT="500"
DATAGOV_API_KEY=""
PLANNING_AREA_DATASET_ID="d_4765db0e87b9c86336792efe8a1f7a66"
CONFIG_COUNTRIES_DIR="../config/countries"
CONFIG_PROMPTS_DIR="../config/prompts"
